# ── Default Provider (fallback if LLM_* or EMBEDDING_* not set) ──
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=

# ── LLM Provider (chat completions) ──
# Leave blank to use OPENROUTER_* above.
# To switch provider, set BOTH LLM_API_KEY + LLM_BASE_URL:
#   OpenAI:    LLM_BASE_URL=https://api.openai.com/v1
#   Gemini:    LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   DeepSeek:  LLM_BASE_URL=https://api.deepseek.com/v1
#   Groq:      LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TITLE_MODEL=

# ── Embedding Provider (vector embeddings) ──
# Leave blank to use OPENROUTER_* above.
# To switch provider, set BOTH EMBEDDING_API_KEY + EMBEDDING_BASE_URL:
#   OpenAI:    EMBEDDING_BASE_URL=https://api.openai.com/v1
#   Gemini:    EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
